{
  "@context": {
    "@version": 1.1,
    "sns": "https://docs.aws.amazon.com/sns/latest/api/schemas/",
    "aws": "https://docs.aws.amazon.com/general/latest/gr/schemas/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Topic": {
      "@id": "sns:Topic",
      "@context": {
        "topicArn": {
          "@id": "aws:arn",
          "@type": "@id"
        },
        "name": "schema:name",
        "displayName": "sns:displayName",
        "owner": "sns:owner",
        "policy": "sns:policy",
        "deliveryPolicy": "sns:deliveryPolicy",
        "effectiveDeliveryPolicy": "sns:effectiveDeliveryPolicy",
        "kmsMasterKeyId": "sns:kmsMasterKeyId",
        "fifoTopic": {
          "@id": "sns:fifoTopic",
          "@type": "xsd:boolean"
        },
        "contentBasedDeduplication": {
          "@id": "sns:contentBasedDeduplication",
          "@type": "xsd:boolean"
        },
        "subscriptionsConfirmed": {
          "@id": "sns:subscriptionsConfirmed",
          "@type": "xsd:integer"
        },
        "subscriptionsPending": {
          "@id": "sns:subscriptionsPending",
          "@type": "xsd:integer"
        },
        "subscriptionsDeleted": {
          "@id": "sns:subscriptionsDeleted",
          "@type": "xsd:integer"
        },
        "dataProtectionPolicy": "sns:dataProtectionPolicy",
        "tracingConfig": "sns:tracingConfig",
        "signatureVersion": "sns:signatureVersion",
        "tags": {
          "@id": "sns:tags",
          "@container": "@set"
        }
      }
    },

    "Subscription": {
      "@id": "sns:Subscription",
      "@context": {
        "subscriptionArn": {
          "@id": "aws:arn",
          "@type": "@id"
        },
        "topicArn": {
          "@id": "sns:topicArn",
          "@type": "@id"
        },
        "protocol": "sns:protocol",
        "endpoint": {
          "@id": "sns:endpoint",
          "@type": "@id"
        },
        "owner": "sns:owner",
        "filterPolicy": "sns:filterPolicy",
        "filterPolicyScope": "sns:filterPolicyScope",
        "deliveryPolicy": "sns:deliveryPolicy",
        "rawMessageDelivery": {
          "@id": "sns:rawMessageDelivery",
          "@type": "xsd:boolean"
        },
        "redrivePolicy": "sns:redrivePolicy",
        "subscriptionRoleArn": {
          "@id": "sns:subscriptionRoleArn",
          "@type": "@id"
        },
        "confirmationWasAuthenticated": {
          "@id": "sns:confirmationWasAuthenticated",
          "@type": "xsd:boolean"
        },
        "pendingConfirmation": {
          "@id": "sns:pendingConfirmation",
          "@type": "xsd:boolean"
        }
      }
    },

    "Notification": {
      "@id": "sns:Notification",
      "@context": {
        "messageId": {
          "@id": "dcterms:identifier",
          "@type": "xsd:string"
        },
        "topicArn": {
          "@id": "sns:topicArn",
          "@type": "@id"
        },
        "subject": "dcterms:subject",
        "message": "sns:message",
        "timestamp": {
          "@id": "dcterms:date",
          "@type": "xsd:dateTime"
        },
        "signatureVersion": "sns:signatureVersion",
        "signature": "sns:signature",
        "signingCertURL": {
          "@id": "sns:signingCertURL",
          "@type": "@id"
        },
        "unsubscribeURL": {
          "@id": "sns:unsubscribeURL",
          "@type": "@id"
        },
        "messageAttributes": {
          "@id": "sns:messageAttributes",
          "@container": "@index"
        }
      }
    },

    "PublishRequest": {
      "@id": "sns:PublishRequest",
      "@context": {
        "topicArn": {
          "@id": "sns:topicArn",
          "@type": "@id"
        },
        "targetArn": {
          "@id": "sns:targetArn",
          "@type": "@id"
        },
        "phoneNumber": "schema:telephone",
        "message": "sns:message",
        "subject": "dcterms:subject",
        "messageStructure": "sns:messageStructure",
        "messageAttributes": {
          "@id": "sns:messageAttributes",
          "@container": "@index"
        },
        "messageDeduplicationId": "sns:messageDeduplicationId",
        "messageGroupId": "sns:messageGroupId"
      }
    },

    "PublishResult": {
      "@id": "sns:PublishResult",
      "@context": {
        "messageId": {
          "@id": "dcterms:identifier",
          "@type": "xsd:string"
        },
        "sequenceNumber": {
          "@id": "sns:sequenceNumber",
          "@type": "xsd:string"
        }
      }
    },

    "PlatformApplication": {
      "@id": "sns:PlatformApplication",
      "@context": {
        "platformApplicationArn": {
          "@id": "aws:arn",
          "@type": "@id"
        },
        "name": "schema:name",
        "platform": "sns:platform",
        "attributes": {
          "@id": "sns:attributes",
          "@container": "@index"
        },
        "enabled": {
          "@id": "sns:enabled",
          "@type": "xsd:boolean"
        }
      }
    },

    "PlatformEndpoint": {
      "@id": "sns:PlatformEndpoint",
      "@context": {
        "endpointArn": {
          "@id": "aws:arn",
          "@type": "@id"
        },
        "token": "sns:token",
        "enabled": {
          "@id": "sns:enabled",
          "@type": "xsd:boolean"
        },
        "customUserData": "sns:customUserData"
      }
    },

    "SmsMessage": {
      "@id": "sns:SmsMessage",
      "@context": {
        "phoneNumber": "schema:telephone",
        "message": "sns:message",
        "senderId": "sns:senderId",
        "smsType": "sns:smsType",
        "maxPrice": {
          "@id": "sns:maxPrice",
          "@type": "xsd:decimal"
        }
      }
    },

    "Tag": {
      "@id": "sns:Tag",
      "@context": {
        "key": "sns:tagKey",
        "value": "sns:tagValue"
      }
    },

    "MessageAttribute": {
      "@id": "sns:MessageAttribute",
      "@context": {
        "dataType": "sns:dataType",
        "stringValue": {
          "@id": "sns:stringValue",
          "@type": "xsd:string"
        },
        "binaryValue": {
          "@id": "sns:binaryValue",
          "@type": "xsd:base64Binary"
        }
      }
    },

    "SubscriptionConfirmation": {
      "@id": "sns:SubscriptionConfirmation",
      "@context": {
        "messageId": {
          "@id": "dcterms:identifier",
          "@type": "xsd:string"
        },
        "topicArn": {
          "@id": "sns:topicArn",
          "@type": "@id"
        },
        "token": "sns:confirmationToken",
        "subscribeURL": {
          "@id": "sns:subscribeURL",
          "@type": "@id"
        },
        "message": "sns:message",
        "timestamp": {
          "@id": "dcterms:date",
          "@type": "xsd:dateTime"
        }
      }
    },

    "DeliveryPolicy": {
      "@id": "sns:DeliveryPolicy",
      "@context": {
        "healthyRetryPolicy": "sns:healthyRetryPolicy",
        "throttlePolicy": "sns:throttlePolicy",
        "numRetries": {
          "@id": "sns:numRetries",
          "@type": "xsd:integer"
        },
        "numNoDelayRetries": {
          "@id": "sns:numNoDelayRetries",
          "@type": "xsd:integer"
        },
        "minDelayTarget": {
          "@id": "sns:minDelayTarget",
          "@type": "xsd:integer"
        },
        "maxDelayTarget": {
          "@id": "sns:maxDelayTarget",
          "@type": "xsd:integer"
        },
        "backoffFunction": "sns:backoffFunction"
      }
    },

    "FilterPolicy": {
      "@id": "sns:FilterPolicy",
      "@context": {
        "scope": "sns:filterPolicyScope",
        "conditions": {
          "@id": "sns:filterConditions",
          "@container": "@index"
        }
      }
    }
  }
}
